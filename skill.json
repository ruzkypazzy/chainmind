  "description": "Multi-modal onchain intelligence skill for Pharos Network - combining visual analysis, document parsing, transaction pattern recognition, cross-chain correlation, and natural language to onchain actions",
  "author": "Developer",
  "supported_chains": [
    "pacific_mainnet",
    "atlantic_testnet"
  ],
